<!DOCTYPE html>
<html lang="en">
<head>
  <title>Mini Jira</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="apple-touch-icon" href="/icon.png">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js" defer></script>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

  <style>
    /* General styles */
    body {
      font-family: 'Arial', sans-serif;
      # background-color: #eaf4fc; /* Changed home screen background color */
      margin: 0;
      padding: 0;
      background-color:yellow;
    }

    /* Navbar styles */
    .navbar {
      background-color: #2c3e50;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.15);
    }

    .navbar-brand {
      font-size: 1.8rem;
      font-weight: bold;
      color: #ffffff !important;
    }

    .nav-link {
      color: #dfe6e9 !important;
      font-size: 1.1rem;
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 15px;
      border-radius: 5px;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    .nav-link:hover {
      background-color: #34495e !important;
      color: #ecf0f1 !important;
    }

    /* Container styles */
    .container {
      max-width: 900px;
      margin: 20px auto;
      background: green;
      padding: 25px;
      border-radius: 10px;
      box-shadow: 0 3px 15px rgba(0, 0, 0, 0.1);
    }

    /* Button styles */
    .btn-show {
      display: inline-block;
      padding: 10px 20px;
      background-color: #3498db;
      color: #ffffff;
      text-decoration: none;
      border-radius: 5px;
      font-size: 1rem;
      font-weight: bold;
      transition: background-color 0.3s ease;
    }

    .btn-show:hover {
      background-color: #2980b9;
    }

    /* Footer styles */
    footer {
      text-align: center;
      padding: 15px 0;
      background-color: #2c3e50;
      color: #ecf0f1;
      font-size: 0.9rem;
      margin-top: 40px;
    }

    footer a {
      color: #1abc9c;
      text-decoration: none;
    }

    footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="#"><i class="fa-solid fa-bug"></i> Mini Jira</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <%= link_to raw('<i class="fa-solid fa-chart-line"></i> Dashboard'), root_path, class: 'nav-link' %>
          </li>
          <li class="nav-item">
            <%= link_to raw('<i class="fa-solid fa-folder"></i> Projects'), projects_path, class: 'nav-link' %>
          </li>
          <li class="nav-item">
            <%= link_to raw('<i class="fa-solid fa-tasks"></i> Tasks'), '#', class: 'nav-link' %>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="container">
    <h1 class="text-center my-4" style="font-size: 2rem; font-weight: bold; color: white;">Welcome to Mini Jira</h1>

    <!-- Example Project Section -->
    <div style="border: 1px solid #ddd; padding: 16px; border-radius: 10px; background-color: #ffffff; margin-bottom: 15px;">
      <h2 style="color: #2c3e50;">Project Title</h2>
      <p style="color: #7f8c8d;">Mini Jira is a simplified project management tool inspired by the functionality of Jira. It is designed to help teams manage projects and tasks efficiently. The application provides an intuitive interface for tracking progress, assigning tasks, and managing projects in real time. Built using Ruby on Rails with Hotwire and Turbo for dynamic updates, Mini Jira ensures a seamless and interactive user experience.</p>
      <%= link_to 'Show', '#', class: 'btn-show' %>
    </div>

    <%= yield %>
  </div>

  <!-- Footer -->
  <footer>
    &copy; <%= Time.now.year %> Mini Jira. All rights reserved. | <a href="#">Privacy Policy</a>
  </footer>
</body>
</html>
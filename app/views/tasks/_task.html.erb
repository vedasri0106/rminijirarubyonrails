<div class="card mb-2">
  <div class="card-body">
    <h5 class="card-title"><%= task.title %> - <%= task.status.humanize %></h5>
    <p class="card-text"><%= task.description %></p>
    <p class="text-muted">Assigned to: <%= User.find(task.assigned_to_id).username %></p>
    <%= link_to "Edit", edit_task_path(task), class: "btn btn-warning btn-sm" %>
    <%= link_to "Delete", task_path(task), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
  </div>
</div>